{
  "manifest_version": 3,
  "name": "Mini Player Extension",
  "version": "1.0.0",
  "description": "Mini Player แบบหน้าต่างแยกสำหรับวิดีโอในแท็บปัจจุบัน",
  "permissions": [
    "activeTab",
    "tabCapture",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Mini Player",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "minimum_chrome_version": "114"
}
